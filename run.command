#!/bin/bash
# 현재 스크립트가 있는 디렉터리로 이동
cd "$(dirname "$0")"

echo "=========================================="
echo "   통장 쪼개기 시뮬레이터 시작 중... (Port: 8083)"
echo "=========================================="

# 의존성 설치 여부 확인 후 개발 서버 실행
if [ ! -d "node_modules" ]; then
    echo "의존성 라이브러리가 없습니다. 설치를 시작합니다..."
    npm install
fi

npm run dev
